    else:
        sim = df_q.copy()

        if "area" not in sim.columns:
            st.warning("Banco sem coluna de grande área.")
        elif "assunto" not in sim.columns:
            st.warning("Banco sem coluna de assunto.")
        else:
            sim["area"] = sim["area"].fillna("").astype(str)
            sim["assunto"] = sim["assunto"].fillna("").astype(str)

            areas = sorted([a for a in sim["area"].unique() if a.strip() and a != "Não classificada"])

            selecoes = []

            st.subheader("Selecionar áreas e assuntos")

            for area in areas:
                df_area = sim[sim["area"] == area].copy()
                total_area = len(df_area)

                with st.expander(f"📚 {area} — {total_area} questões disponíveis", expanded=False):
                    usar_area = st.checkbox(
                        f"Usar {area}",
                        key=f"usar_area_{area}"
                    )

                    if usar_area:
                        assuntos = sorted([a for a in df_area["assunto"].unique() if a.strip()])

                        for assunto in assuntos:
                            df_assunto = df_area[df_area["assunto"] == assunto]
                            disponiveis = len(df_assunto)

                            col_a, col_b = st.columns([4, 1])

                            with col_a:
                                usar_assunto = st.checkbox(
                                    f"{assunto} ({disponiveis} disponíveis)",
                                    key=f"usar_assunto_{area}_{assunto}"
                                )

                            with col_b:
                                qtd_assunto = st.number_input(
                                    "Qtd",
                                    min_value=0,
                                    max_value=max(0, disponiveis),
                                    value=0,
                                    step=1,
                                    key=f"qtd_{area}_{assunto}"
                                )

                            if usar_assunto and qtd_assunto > 0:
                                selecoes.append({
                                    "area": area,
                                    "assunto": assunto,
                                    "quantidade": int(qtd_assunto)
                                })

            st.divider()
            st.subheader("Resumo da seleção")

            if not selecoes:
                st.info("Marque uma ou mais áreas/assuntos e informe a quantidade de questões.")
            else:
                df_selecoes = pd.DataFrame(selecoes)
                st.dataframe(df_selecoes, use_container_width=True)
                st.metric("Total de questões selecionadas", int(df_selecoes["quantidade"].sum()))

                if st.button("Gerar simulado", type="primary"):
                    partes = []

                    for item in selecoes:
                        pool = sim[
                            (sim["area"] == item["area"]) &
                            (sim["assunto"] == item["assunto"])
                        ].copy()

                        qtd = int(item["quantidade"])

                        if len(pool) >= qtd:
                            amostra = pool.sample(n=qtd, random_state=42)
                        else:
                            amostra = pool

                        partes.append(amostra)

                    if partes:
                        sim_final = pd.concat(partes, ignore_index=True)
                    else:
                        sim_final = pd.DataFrame()

                    if sim_final.empty:
                        st.warning("Nenhuma questão foi selecionada.")
                    else:
                        st.success(f"Simulado gerado com {len(sim_final)} questões.")
                        st.dataframe(sim_final, use_container_width=True)

                        st.download_button(
                            "Exportar CSV",
                            sim_final.to_csv(index=False).encode("utf-8-sig"),
                            "simulado_personalizado.csv",
                            "text/csv"
                        )

                        st.download_button(
                            "Exportar Word",
