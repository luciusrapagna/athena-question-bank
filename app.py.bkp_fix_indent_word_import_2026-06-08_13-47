def corrigir_texto_word(texto):
    texto = str(texto or "")

    # Remove caracteres proibidos no XML/DOCX
    texto = texto.replace("\x00", "")
    texto = re.sub(r"[\x01-\x08\x0B\x0C\x0E-\x1F\x7F-\x9F]", " ", texto)

    # Remove caracteres Unicode problemáticos para XML
    texto = "".join(
        ch for ch in texto
        if (
            ch == "\t"
            or ch == "\n"
            or ch == "\r"
            or ord(ch) >= 32
        )
    )

    substituicoes = {
        "YHORFLGDGH": "velocidade",
        "D¿YHODGR": "afivelado",
        "WRPRJUD¿D": "tomografia",
        "Gp¿FLW": "déficit",
        "ItVLFR": "físico",
        "LQYHVWLJDomR": "investigação",
        "SHULWRQHDO": "peritoneal",
        "VDQJUDPHQWR": "sangramento",
        "UHVSLUD": "respira",
        "HVSRQWDQHDPHQWH": "espontaneamente",
        "YHUEDLV": "verbais",
        "QmR": "não",
        "Ki": "há",
        "UiV": "trás",
        "WUiV": "trás",
        "VHJXUDQoD": "segurança",
        "DGRWDU": "adotar",
        "PRGL¿FDU": "modificar",
        "PpGLFRV": "médicos",
    }

    for errado, certo in substituicoes.items():
        texto = texto.replace(errado, certo)

    texto = re.sub(r"\s+", " ", texto).strip()
    return texto


def extrair_alternativas_do_enunciado(enunciado):
    """
    Extrai alternativas coladas no enunciado nos padrões:
    A) texto B) texto...
    A. texto B. texto...
    A texto B texto...
    """
    texto = corrigir_texto_word(enunciado)

    padrao = r"\s([A-E])[\)\.]?\s+"
    partes = re.split(padrao, texto)

    if len(partes) < 7:
        return texto, {}

    enun = partes[0].strip()
    alternativas = {}

    i = 1
    while i < len(partes) - 1:
        letra = partes[i].lower()
        conteudo = partes[i + 1].strip()
        if letra in ["a", "b", "c", "d", "e"] and conteudo:
            alternativas[letra] = conteudo
        i += 2

    # Só aceita extração se encontrou pelo menos 3 alternativas
    if len(alternativas) >= 3:
        return enun, alternativas

    return texto, {}


def eh_discursiva(texto):
    t = str(texto or "").lower()
    gatilhos = [
        "descreva",
        "explique",
        "justifique",
        "disserte",
        "valor:",
        "pontos)",
        "rascunho"
    ]
    return any(g in t for g in gatilhos)



def questao_corrompida_word(texto):
    texto = str(texto or "")
    marcadores = [
        "VHQ", "DGR", "FRP", "QR", "GH", "HVWi", "SRGHUi",
        "LQWH", "VHU", "¿", "DYDOLD", "TXD", "GRV"
    ]
    achados = sum(1 for m in marcadores if m in texto)
    return achados >= 5



def preparar_questao_word(q):
    q = dict(q)

    enunciado = corrigir_texto_word(q.get("enunciado", ""))
    enunciado_limpo, alternativas_extraidas = extrair_alternativas_do_enunciado(enunciado)

    q["enunciado"] = enunciado_limpo

    for letra in ["a", "b", "c", "d", "e"]:
        campo = f"alternativa_{letra}"
        valor_atual = corrigir_texto_word(q.get(campo, ""))

        # Se alternativa está vazia, usa a extraída
        if not valor_atual and letra in alternativas_extraidas:
            q[campo] = alternativas_extraidas[letra]

        # Se alternativa atual repete quase o enunciado, substitui pela extraída ou limpa
        elif valor_atual and len(valor_atual) > 250 and letra in alternativas_extraidas:
            q[campo] = alternativas_extraidas[letra]

        else:
            q[campo] = valor_atual

    # Se for discursiva, não imprime alternativas
    q["_discursiva"] = eh_discursiva(enunciado)

    return q


def gerar_docx(questoes, titulo):
    doc = Document()

    h = doc.add_heading("ATHENA QUESTION BANK", level=1)
    h.alignment = WD_ALIGN_PARAGRAPH.CENTER

    subt = doc.add_paragraph(titulo)
    subt.alignment = WD_ALIGN_PARAGRAPH.CENTER

    questoes_validas = []
    for q in questoes:
        q2 = preparar_questao_word(q)
        if not questao_corrompida_word(q2.get("enunciado", "")):
            questoes_validas.append(q2)

    doc.add_paragraph(f"Total de questões: {len(questoes_validas)}")

    for i, q in enumerate(questoes_validas, 1):
        area_doc = limpar_campo_word(q.get('area','') or q.get('grande_area',''))
        assunto_doc = limpar_campo_word(q.get('assunto','') or q.get('tema_indexado','') or q.get('tema',''))
        competencia_doc = limpar_campo_word(q.get('competencia_enamed','') or q.get('competencia',''))
        habilidade_doc = limpar_campo_word(q.get('habilidade_enamed','') or q.get('habilidade',''))
        fonte_doc = limpar_campo_word(q.get("fonte", "") or q.get("prova", ""))
        ano_doc = limpar_campo_word(q.get("ano", ""))
        ano_doc = ano_doc.replace(".0", "")
        prova_doc = limpar_campo_word(q.get("prova", ""))

        tipo = "Discursiva" if q.get("_discursiva") else "Objetiva"

        doc.add_heading(f"QUESTÃO {i:02d}", level=2)

        metadados = (
            f"Fonte: {fonte_doc or prova_doc} {ano_doc} | Tipo: {tipo} | "
            f"Área: {area_doc} | Assunto: {assunto_doc} | "
            f"Competência ENAMED: {competencia_doc} | "
            f"Habilidade ENAMED: {habilidade_doc}"
        )

        doc.add_paragraph(corrigir_texto_word(metadados))
        doc.add_paragraph(corrigir_texto_word(q.get("enunciado", "")))

        if not q.get("_discursiva"):
            for letra, campo in [
                ("A", "alternativa_a"),
                ("B", "alternativa_b"),
                ("C", "alternativa_c"),
                ("D", "alternativa_d"),
                ("E", "alternativa_e"),
            ]:
                alt = limpar_campo_word(corrigir_texto_word(q.get(campo, "")))
                if alt and not questao_corrompida_word(alt):
                    doc.add_paragraph(f"{letra}) {alt}")

        if q.get("gabarito"):
            doc.add_paragraph(f"Gabarito: {limpar_campo_word(q.get('gabarito'))}")

    bio = BytesIO()
    doc.save(bio)
    bio.seek(0)
    return bio.getvalue()


