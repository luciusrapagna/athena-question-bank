def formatar_data_br(data):
    data = str(data or "").strip()

    formatos = [
        ("%Y-%m-%d", True),
        ("%d/%m/%Y", True),
        ("%d/%m/%y", True),
        ("%d/%m", False),
    ]

    for fmt, tem_ano in formatos:
        try:
            d = datetime.strptime(data, fmt)

            if tem_ano:
                return d.strftime("%d/%m/%Y")

            return d.strftime("%d/%m")

        except:
            pass

    return data


