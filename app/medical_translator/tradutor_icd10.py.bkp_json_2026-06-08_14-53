HABILIDADE_PADRAO = (
    "Interpretar dados clínicos, reconhecer hipóteses diagnósticas "
    "e selecionar condutas."
)

def classificar_icd10(icd10):
    if not icd10:
        return None

    letra = str(icd10).strip().upper()[0]

    if letra not in MAPA_ICD10:
        return None

    especialidade, area = MAPA_ICD10[letra]

    return {
        "area": area,
        "especialidade": especialidade,
        "competencia": COMPETENCIAS.get(area, ""),
        "habilidade": HABILIDADE_PADRAO
    }

