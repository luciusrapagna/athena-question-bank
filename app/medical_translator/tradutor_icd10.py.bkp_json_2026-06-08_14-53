def classificar_por_nome(termo):
    if not termo:
        return None

    termo = str(termo).lower()

    for chave, (esp, area) in MAPA_TERMOS.items():
        if chave in termo:
            return {
                "area": area,
                "especialidade": esp,
                "competencia": COMPETENCIAS.get(area, ""),
                "habilidade": HABILIDADE_PADRAO
            }

    return None
